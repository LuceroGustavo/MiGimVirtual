#!/bin/bash
# migimvirtual - Menú de gestión (ejecutar desde la raíz del proyecto: ./migimvirtual)
# Servidor: Donweb - 149.50.144.53 | Puerto: 8080

# Directorio del proyecto = donde está este script (raíz del repo)
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR_NAME="migimvirtual-0.0.1-SNAPSHOT.jar"
JAR_PATH="$APP_DIR/target/$JAR_NAME"
LOG_FILE="$APP_DIR/logs/migimvirtual.log"
PID_FILE="$APP_DIR/migimvirtual.pid"
SPRING_PROFILE="donweb"
# VPS / despliegue: .env.production (no commitear; chmod 600). Cargar ANTES de fijar APP_PORT.
if [ -f "$APP_DIR/.env.production" ]; then
  set -a
  # shellcheck source=/dev/null
  source "$APP_DIR/.env.production"
  set +a
fi
# Cargar variables de BD: .bashrc (sesión interactiva) o archivo .migimvirtual_db_password en el proyecto (servidor)
[ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc"
[ -z "$MIGIMVIRTUAL_DB_PASSWORD" ] && [ -f "$APP_DIR/.migimvirtual_db_password" ] && export MIGIMVIRTUAL_DB_PASSWORD=$(cat "$APP_DIR/.migimvirtual_db_password" | tr -d '\n\r')
# Puerto: debe leerse después de .env.production y .bashrc (si no, queda 8080 y choca con Mattfuncional).
APP_PORT="${MIGIMVIRTUAL_APP_PORT:-8080}"
JAVA_DB_OPTS=""
[ -n "$MIGIMVIRTUAL_DB_USER" ] && JAVA_DB_OPTS="$JAVA_DB_OPTS -Dspring.datasource.username=$MIGIMVIRTUAL_DB_USER"
[ -n "$MIGIMVIRTUAL_DB_PASSWORD" ] && JAVA_DB_OPTS="$JAVA_DB_OPTS -Dspring.datasource.password=$MIGIMVIRTUAL_DB_PASSWORD"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

print_header() {
    echo -e "${CYAN}=========================================="
    echo -e "   MIGIMVIRTUAL - MENÚ DE GESTIÓN"
    echo -e "==========================================${NC}"
}

print_option() { echo -e "${BLUE}$1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }

get_pid() {
    if [ -f "$PID_FILE" ]; then cat "$PID_FILE"
    else pgrep -f "migimvirtual.*$JAR_NAME" 2>/dev/null || echo ""
    fi
}

check_app_status() {
    if pgrep -f "migimvirtual.*$JAR_NAME" > /dev/null; then
        PID=$(get_pid); [ -z "$PID" ] && PID=$(pgrep -f "migimvirtual.*$JAR_NAME")
        echo -e "${GREEN}◆ MiGymVirtual corriendo (PID: $PID) - Puerto $APP_PORT${NC}"
        return 0
    else
        echo -e "${RED}◆ MiGymVirtual no está corriendo${NC}"
        return 1
    fi
}

stop_app() {
    print_option "1️⃣ Parando aplicación MiGymVirtual..."
    if pgrep -f "migimvirtual.*$JAR_NAME" > /dev/null; then
        pkill -f "migimvirtual.*$JAR_NAME"
        sleep 3
        if pgrep -f "migimvirtual.*$JAR_NAME" > /dev/null; then
            print_warning "Forzando cierre..."
            pkill -9 -f "migimvirtual.*$JAR_NAME"
        fi
        rm -f "$PID_FILE"
        print_success "Aplicación MiGymVirtual detenida"
    else
        print_warning "No hay aplicación MiGymVirtual corriendo"
    fi
}

update_code() {
    print_option "2️⃣ Actualizando código desde GitHub..."
    cd "$APP_DIR" || { print_error "Error: No se pudo cambiar al directorio del proyecto"; return 1; }
    # VPS = copia del remoto: fetch + reset evita merges a medias y conflictos tras stash+pull.
    # No borra .env.production, uploads/ ni otros ignorados por .gitignore.
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        print_warning "Descartando cambios locales en archivos versionados (alineación con origin)"
    fi
    git fetch origin
    if git rev-parse --verify origin/main > /dev/null 2>&1; then
        if git reset --hard origin/main; then
            print_success "Código alineado con origin/main"
        else
            print_error "Error al actualizar código desde main"
            return 1
        fi
    else
        if git rev-parse --verify origin/master > /dev/null 2>&1; then
            if git reset --hard origin/master; then
                print_success "Código alineado con origin/master"
            else
                print_error "Error al actualizar código desde master"
                return 1
            fi
        else
            print_error "No se encontró origin/main ni origin/master"
            return 1
        fi
    fi
}

compile_app() {
    print_option "3️⃣ Compilando aplicación MiGymVirtual..."
    print_warning "Esto puede tomar varios minutos..."
    cd "$APP_DIR" || { print_error "Error: No se pudo cambiar al directorio del proyecto"; return 1; }
    if [ -x "./mvnw" ]; then
        ./mvnw clean package -DskipTests -q
    else
        mvn clean package -DskipTests -q
    fi
    if [ $? -eq 0 ]; then print_success "Compilación exitosa"
    else print_error "Error en la compilación"; return 1
    fi
}

start_app() {
    print_option "4️⃣ Iniciando aplicación MiGymVirtual..."
    cd "$APP_DIR" || { print_error "Error: No se pudo cambiar al directorio del proyecto"; return 1; }
    if [ ! -f "$JAR_PATH" ]; then
        print_error "No se encontró el JAR. Compila primero (opción 3)"
        return 1
    fi
    if command -v ss >/dev/null 2>&1; then
        if ss -tlnp 2>/dev/null | grep -q ":$APP_PORT "; then
            if ! pgrep -f "migimvirtual.*$JAR_NAME" > /dev/null; then
                print_error "Puerto $APP_PORT está ocupado por otra aplicación"
                ss -tlnp | grep ":$APP_PORT " || true
                return 1
            fi
        fi
    else
        if netstat -tlnp 2>/dev/null | grep -q ":$APP_PORT " && ! pgrep -f "migimvirtual.*$JAR_NAME" > /dev/null; then
            print_error "Puerto $APP_PORT está ocupado"
            return 1
        fi
    fi
    mkdir -p "$(dirname "$LOG_FILE")"
    nohup java -Xmx512m -Xms256m \
        $JAVA_DB_OPTS \
        -Dspring.profiles.active=$SPRING_PROFILE \
        -Dserver.port=$APP_PORT \
        -Dserver.address=0.0.0.0 \
        -jar "$JAR_PATH" \
        >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 5
    if check_app_status; then
        print_success "Aplicación MiGymVirtual iniciada correctamente"
        echo -e "${CYAN}🌐 Disponible en: http://149.50.144.53:$APP_PORT${NC}"
    else
        print_error "Error al iniciar la aplicación"
        print_warning "Revisa los logs: tail -f $LOG_FILE"
    fi
}

full_deploy() {
    print_option "5️⃣ Despliegue completo iniciado..."
    stop_app
    update_code
    compile_app || return 1
    start_app
    echo ""
    print_success "🎉 Despliegue completo de MiGymVirtual finalizado"
}

system_status() {
    print_option "6️⃣ Estado del sistema:"
    echo ""
    echo -e "${CYAN}=== APLICACIÓN MIGIMVIRTUAL ===${NC}"
    check_app_status
    echo ""
    echo -e "${CYAN}=== RECURSOS DEL SERVIDOR ===${NC}"
    echo "Uso de CPU y memoria:"
    top -bn1 | head -5
    echo ""
    echo -e "${CYAN}=== ESPACIO EN DISCO ===${NC}"
    df -h | grep -E "(Filesystem|/dev/)" | head -5
    echo ""
    echo -e "${CYAN}=== MEMORIA ===${NC}"
    free -h
    echo ""
    echo -e "${CYAN}=== PUERTO EN USO ===${NC}"
    if command -v ss >/dev/null 2>&1; then
        ss -tlnp | grep ":$APP_PORT " || echo "  No hay aplicación en puerto $APP_PORT"
    else
        netstat -tlnp 2>/dev/null | grep ":$APP_PORT " || echo "  No hay aplicación en puerto $APP_PORT"
    fi
}

view_logs() {
    print_option "7️⃣ Mostrando logs de la aplicación MiGymVirtual..."
    if [ -f "$LOG_FILE" ]; then
        echo -e "${YELLOW}Últimas 50 líneas de logs:${NC}"
        tail -50 "$LOG_FILE"
        echo ""
    elif [ -f "$APP_DIR/nohup.out" ]; then
        echo -e "${YELLOW}Últimas 50 líneas de logs:${NC}"
        tail -50 "$APP_DIR/nohup.out"
    else
        print_warning "No se encontró archivo de logs"
    fi
}

restart_app() {
    print_option "8️⃣ Reiniciando aplicación MiGymVirtual..."
    stop_app
    sleep 2
    start_app
}

project_info() {
    print_option "9️⃣ Información del proyecto MiGymVirtual:"
    cd "$APP_DIR" || { print_error "Error: No se pudo cambiar al directorio del proyecto"; return 1; }
    echo ""
    echo -e "${CYAN}=== INFORMACIÓN GIT ===${NC}"
    echo "Rama actual: $(git branch --show-current 2>/dev/null || echo 'N/A')"
    echo "Último commit: $(git log -1 --oneline 2>/dev/null || echo 'N/A')"
    echo "Estado: $(git status --porcelain 2>/dev/null | wc -l) archivos modificados"
    echo ""
    echo -e "${CYAN}=== INFORMACIÓN DEL PROYECTO ===${NC}"
    echo "Directorio: $APP_DIR"
    echo "JAR disponible: $([ -f "$JAR_PATH" ] && echo "Sí" || echo "No")"
    echo "Tamaño del JAR: $([ -f "$JAR_PATH" ] && du -h "$JAR_PATH" | cut -f1 || echo "N/A")"
    echo ""
    echo -e "${CYAN}=== CONFIGURACIÓN ===${NC}"
    echo "Servidor: Donweb | IP: 149.50.144.53 | Puerto: $APP_PORT | Perfil: $SPRING_PROFILE | BD: migimvirtual"
    echo ""
    echo -e "${CYAN}=== APLICACIÓN MIGIMVIRTUAL ===${NC}"
    check_app_status
}

disk_space() {
    print_option "🔟 Espacio en disco:"
    echo ""
    echo -e "${CYAN}=== ESPACIO TOTAL DEL SERVIDOR ===${NC}"
    df -h / | awk 'NR==1 || NR==2 {print}'
    USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    AVAILABLE=$(df -h / | tail -1 | awk '{print $4}')
    USED=$(df -h / | tail -1 | awk '{print $3}')
    TOTAL=$(df -h / | tail -1 | awk '{print $2}')
    echo ""
    echo -e "${BLUE}📊 Resumen:${NC}"
    echo "  Total: $TOTAL | Usado: $USED | Disponible: $AVAILABLE | Uso: ${USAGE}%"
    if [ "$USAGE" -ge 90 ]; then print_error "⚠️  CRÍTICO: Espacio en disco muy bajo (${USAGE}%)"
    elif [ "$USAGE" -ge 80 ]; then print_warning "⚠️  Espacio en disco bajo (${USAGE}%)"
    else print_success "Espacio en disco OK (${USAGE}%)"
    fi
    echo ""
    echo -e "${CYAN}=== PROYECTO MIGIMVIRTUAL ===${NC}"
    [ -d "$APP_DIR" ] && echo "📦 Proyecto ($APP_DIR):" && du -sh "$APP_DIR" 2>/dev/null | awk '{print "   Tamaño: " $1}'
    [ -d "/root/migimvirtual/uploads" ] && echo "📁 Uploads (/root/migimvirtual/uploads):" && du -sh /root/migimvirtual/uploads 2>/dev/null | awk '{print "   Tamaño: " $1}'
    echo ""
    echo -e "${CYAN}=== TOP DIRECTORIOS EN /root ===${NC}"
    du -h --max-depth=1 /root 2>/dev/null | sort -hr | head -10 | awk '{printf "  %-50s %s\n", $2, $1}'
}

reset_database() {
    print_option "🗑️ Borrar base de datos migimvirtual..."
    if [ -f "$APP_DIR/scripts/servidor/reset_db_migimvirtual.sh" ]; then
        bash "$APP_DIR/scripts/servidor/reset_db_migimvirtual.sh"
        echo ""
        print_warning "Reinicia la aplicación (opción 8) para que Hibernate cree las tablas."
    else
        print_error "No se encontró scripts/servidor/reset_db_migimvirtual.sh"
        echo "Puedes ejecutar manualmente: mysql -u \${MIGIMVIRTUAL_DB_USER:-migimvirtual_user} -p -e \"DROP DATABASE IF EXISTS migimvirtual; CREATE DATABASE migimvirtual;\""
    fi
}

# Menú principal
while true; do
    clear
    print_header
    echo ""
    check_app_status
    echo ""
    print_option "Selecciona una opción:"
    echo ""
    echo "1.  Parar aplicación MiGymVirtual"
    echo "2.  Actualizar código (git pull)"
    echo "3.  Compilar aplicación MiGymVirtual"
    echo "4.  Iniciar aplicación MiGymVirtual"
    echo "5.  Despliegue completo (1+2+3+4)"
    echo "6.  Ver estado del sistema"
    echo "7.  Ver logs de la aplicación"
    echo "8.  Reiniciar aplicación MiGymVirtual"
    echo "9.  Información del proyecto"
    echo "10. Ver espacio en disco"
    echo "11. Borrar base de datos"
    echo "12. Salir del sistema"
    echo ""
    read -p "Ingresa tu opción (1-12): " opcion
    echo ""

    case $opcion in
        1) stop_app ;;
        2) update_code ;;
        3) compile_app ;;
        4) start_app ;;
        5) full_deploy ;;
        6) system_status ;;
        7) view_logs ;;
        8) restart_app ;;
        9) project_info ;;
        10) disk_space ;;
        11) reset_database ;;
        12)
            print_success "Saliendo del menú..."
            exit 0
            ;;
        *)
            print_error "Opción inválida. Presiona Enter para continuar..."
            read
            ;;
    esac

    echo ""
    read -p "Presiona Enter para continuar..."
done
